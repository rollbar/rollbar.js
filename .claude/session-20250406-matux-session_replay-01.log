  6. Expose API Methods for Controlling Recording

  // Add to src/browser/core.js
  Rollbar.prototype.startRecording = function() {
    if (this.rrwebRecorder) {
      this.rrwebRecorder.start();
    } else {
      this.rrwebRecorder = rrweb.createRrwebRecorder(this);
      this.rrwebRecorder.start();
    }
    return this;
  };

  Rollbar.prototype.stopRecording = function() {
    if (this.rrwebRecorder) {
      this.rrwebRecorder.stop();
    }
    return this;
  };

  Rollbar.prototype.getRecording = function(minutes) {
    if (!this.rrwebRecorder) return null;
    return minutes ? this.rrwebRecorder.getLastNMinutes(minutes) : this.rrwebRecorder.getSessionEvents();
  };

