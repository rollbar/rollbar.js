⏺ Based on my analysis of rrweb, the Rollbar SDK architecture, and the requirements, here's a comprehensive plan for the first phase of integrating rrweb's recording capabilities:

  Phase 1: Core Integration Plan

  1. Create an RrwebRecorder Class

  // src/browser/rrweb/recorder.js
  import * as rrweb from 'rrweb';

  export class RrwebRecorder {
    constructor(options = {}) {
      this.options = {
        // Default rrweb options
        checkoutEveryNth: 200,
        blockClass: 'rr-block',
        maskTextClass: 'rr-mask',
        maskInputs: true,
        recordCanvas: false,
        // Time buffer in milliseconds (5 minutes = 300000ms)
        bufferDuration: 300000,
        // Override with user options
        ...options
      };

      this.events = [];
      this.startTime = null;
      this.stopFn = null;
      this.isRecording = false;
    }

    start() {
      if (this.isRecording) return;

      this.startTime = Date.now();
      this.events = [];

      this.stopFn = rrweb.record({
        emit: event => {
          // Add timestamp to event if not present
          if (!event.timestamp) {
            event.timestamp = Date.now();
          }
          this.events.push(event);
          this._pruneOldEvents();
        },
        ...this.options
      });

      this.isRecording = true;
      return this;
    }

    stop() {
      if (!this.isRecording || !this.stopFn) return;

      this.stopFn();
      this.isRecording = false;
      this.stopFn = null;
      return this;
    }

    getEvents() {
      return [...this.events];
    }

    getEventsInTimeRange(startTime, endTime) {
      return this.events.filter(event =>
        event.timestamp >= startTime && event.timestamp <= endTime
      );
    }

    getLastNMinutes(minutes) {
      const timeThreshold = Date.now() - (minutes * 60 * 1000);
      return this.events.filter(event => event.timestamp >= timeThreshold);
    }

    clear() {
      this.events = [];
      return this;
    }

    // Prune events older than the buffer duration, but always keep the first event (initial snapshot)
    _pruneOldEvents() {
      if (this.events.length <= 1) return;

      const threshold = Date.now() - this.options.bufferDuration;
      // Keep the first event (always the full snapshot) and filter the rest
      const initialSnapshot = this.events[0];
      const recentEvents = this.events.slice(1).filter(event => event.timestamp >= threshold);

      this.events = [initialSnapshot, ...recentEvents];
    }
  }

  2. Create a TracingRrwebIntegration Class

  // src/browser/rrweb/tracingIntegration.js
  import { RrwebRecorder } from './recorder';

  export class TracingRrwebIntegration {
    constructor(tracing, options = {}) {
      this.tracing = tracing;
      this.recorder = new RrwebRecorder(options.rrweb || {});
      this.options = {
        // Enable rrweb integration
        enabled: true,
        // Associate rrweb events with spans
        associateWithSpans: true,
        // Start recording automatically
        autoStart: true,
        ...options
      };

      // Holds the current session ID when recording started
      this.sessionId = null;

      if (this.options.enabled && this.options.autoStart) {
        this.start();
      }
    }

    start() {
      if (!this.options.enabled) return this;

      // Get the current session ID from tracing
      if (this.tracing && this.tracing.session) {
        this.tracing.session.init();
        this.sessionId = this.tracing.session.session.id;
      }

      // Start rrweb recording
      this.recorder.start();

      // Create a span for the recording session if tracing is available
      if (this.tracing && this.options.associateWithSpans) {
        this.recordingSpan = this.tracing.startSpan('rrweb.recording', {
          attributes: {
            'rrweb.sessionId': this.sessionId,
            'rrweb.startTime': Date.now()
          }
        });
      }

      return this;
    }

    stop() {
      this.recorder.stop();

      // End the recording span if it exists
      if (this.recordingSpan) {
        this.recordingSpan.end();
        this.recordingSpan = null;
      }

      return this;
    }

    getSessionEvents() {
      return {
        sessionId: this.sessionId,
        events: this.recorder.getEvents()
      };
    }

    getLastNMinutes(minutes = 5) {
      return {
        sessionId: this.sessionId,
        events: this.recorder.getLastNMinutes(minutes)
      };
    }
  }

  3. Create a Factory Function for Integration with the SDK

  // src/browser/rrweb/index.js
  import { RrwebRecorder } from './recorder';
  import { TracingRrwebIntegration } from './tracingIntegration';

  export function createRrwebRecorder(rollbar) {
    if (!rollbar || !rollbar.options) {
      throw new Error('Rollbar instance is required to create an RrwebRecorder');
    }

    const options = rollbar.options.rrweb || {};

    // If tracing is available, create the integration
    if (rollbar.tracing) {
      return new TracingRrwebIntegration(rollbar.tracing, options);
    }

    // Fallback to basic recorder if tracing isn't available
    return new RrwebRecorder(options);
  }

  // Export the classes for direct use if needed
  export { RrwebRecorder, TracingRrwebIntegration };

