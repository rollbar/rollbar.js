      this.replayRecorder.start();
    } else {
      this.replayRecorder = replay.createReplayRecorder(this);
      this.replayRecorder.start();
    }
    return this;
  };

  Rollbar.prototype.stopRecording = function() {
    if (this.replayRecorder) {
      this.replayRecorder.stop();
    }
    return this;
  };

  Rollbar.prototype.getRecording = function(minutes) {
    if (!this.replayRecorder) return null;
    return minutes ? this.replayRecorder.getLastNMinutes(minutes) : this.replayRecorder.getSessionEvents();
  };

